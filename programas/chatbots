    #dw-av{width:38px;height:38px;border-radius:50%;background:rgba(255,255,255,0.2);display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0}
    #dw-hi{flex:1}
    #dw-hn{font-size:14px;font-weight:700;color:#fff}
    #dw-hs{font-size:11px;color:rgba(255,255,255,0.8)}
    #dw-cl{background:none;border:none;color:rgba(255,255,255,0.7);cursor:pointer;font-size:20px;padding:0;line-height:1}
    #dw-msgs{flex:1;overflow-y:auto;padding:14px;display:flex;flex-direction:column;gap:10px}
    #dw-msgs::-webkit-scrollbar{width:3px}
    #dw-msgs::-webkit-scrollbar-thumb{background:rgba(255,255,255,0.1);border-radius:3px}
    .dm{max-width:85%;display:flex;flex-direction:column;gap:3px}
    .dm.u{align-self:flex-end;align-items:flex-end}
    .dm.b{align-self:flex-start;align-items:flex-start}
    .db{padding:10px 13px;border-radius:16px;font-size:13px;line-height:1.6;white-space:pre-line;word-break:break-word}
    .dm.u .db{background:${COLOR};color:#fff;border-radius:16px 16px 4px 16px}
    .dm.b .db{background:#1A1A1A;border:1px solid rgba(255,255,255,0.08);color:#F5F0E8;border-radius:16px 16px 16px 4px}
    .dt{font-size:10px;color:#555;padding:0 3px}
    #dw-qr{display:flex;flex-wrap:wrap;gap:6px;padding:4px 14px 10px;flex-shrink:0}
    .dq{padding:6px 12px;border-radius:20px;font-size:11px;font-weight:500;cursor:pointer;border:1.5px solid ${COLOR};color:${COLOR};background:transparent;font-family:inherit;transition:all 0.2s}
    .dq:hover{background:${COLOR};color:#fff}
    #dw-inp-area{display:flex;gap:8px;padding:12px 14px;border-top:1px solid rgba(255,255,255,0.06);flex-shrink:0}
    #dw-inp{flex:1;padding:9px 14px;border-radius:22px;border:1px solid rgba(255,255,255,0.1);background:#1A1A1A;color:#F5F0E8;font-size:13px;font-family:inherit;outline:none}
    #dw-inp:focus{border-color:${COLOR}}
    #dw-inp::placeholder{color:#555}
    #dw-snd{width:38px;height:38px;border-radius:50%;background:${COLOR};border:none;cursor:pointer;color:#fff;font-size:15px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
    .dw-ty{display:flex;gap:4px;align-items:center;padding:10px 13px}
    .dw-d{width:6px;height:6px;border-radius:50%;background:#666;animation:dw-b 1.2s infinite}
    .dw-d:nth-child(2){animation-delay:0.2s}
    .dw-d:nth-child(3){animation-delay:0.4s}
    @keyframes dw-b{0%,100%{opacity:0.3}50%{opacity:1}}
    #dw-pw{text-align:center;font-size:10px;color:#333;padding:6px;flex-shrink:0}
    #dw-pw a{color:#444;text-decoration:none}
    @media(max-width:400px){#dw-box{width:calc(100vw - 16px);right:8px;bottom:80px}}
  `;
  document.head.appendChild(style);
  const btn=document.createElement('button');
  btn.id='dw-btn';
  btn.innerHTML=`<div id="dw-badge"></div><svg viewBox="0 0 24 24"><path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-2 12H6v-2h12v2zm0-3H6V9h12v2zm0-3H6V6h12v2z"/></svg>`;
  const box=document.createElement('div');
  box.id='dw-box';
  box.innerHTML=`
    <div id="dw-head"><div id="dw-av">🤖</div><div id="dw-hi"><div id="dw-hn">Lucas · Digital Worldwide</div><div id="dw-hs">● En línea · Responde al instante</div></div><button id="dw-cl">✕</button></div>
    <div id="dw-msgs"></div>
    <div id="dw-qr">
      <button class="dq" onclick="dwQ('¿Qué programas tienen?')">Programas</button>
      <button class="dq" onclick="dwQ('¿Qué ebooks tienen?')">Ebooks $2</button>
      <button class="dq" onclick="dwQ('¿Cómo funciona el chatbot?')">Chatbots</button>
      <button class="dq" onclick="dwQ('¿Cuánto cuesta el Bundle?')">Bundle $57</button>
    </div>
    <div id="dw-inp-area"><input id="dw-inp" placeholder="Escribe tu pregunta..."/><button id="dw-snd">➤</button></div>
    <div id="dw-pw"><a href="https://digitalworldwide.net">⚡ Digital Worldwide</a></div>
  `;
  document.body.appendChild(btn);
  document.body.appendChild(box);
  let open=false,shown=false,history=[],sid='dw_'+Date.now();
  btn.onclick=()=>{open=!open;box.classList.toggle('open',open);if(open&&!shown){shown=true;setTimeout(()=>addM('¡Hola! 👋 Soy Lucas. Puedo ayudarte con programas, ebooks o el servicio de chatbots. ¿En qué te ayudo?',false),400);}if(open)document.getElementById('dw-inp').focus();};
  document.getElementById('dw-cl').onclick=()=>{open=false;box.classList.remove('open');};
  document.getElementById('dw-inp').addEventListener('keydown',e=>{if(e.key==='Enter')send();});
  document.getElementById('dw-snd').onclick=send;
  function t(){return new Date().toLocaleTimeString('es',{hour:'2-digit',minute:'2-digit'});}
  function addM(text,isUser){
    const c=document.getElementById('dw-msgs');
    const d=document.createElement('div');d.className='dm '+(isUser?'u':'b');
    const b=document.createElement('div');b.className='db';b.textContent=text;
    const ti=document.createElement('div');ti.className='dt';ti.textContent=t();
    d.appendChild(b);d.appendChild(ti);c.appendChild(d);c.scrollTop=c.scrollHeight;
  }
  function showTyping(){const c=document.getElementById('dw-msgs');const d=document.createElement('div');d.className='dm b';d.id='dw-ty';d.innerHTML='<div class="db"><div class="dw-ty"><div class="dw-d"></div><div class="dw-d"></div><div class="dw-d"></div></div></div>';c.appendChild(d);c.scrollTop=c.scrollHeight;}
  function rmTyping(){const t=document.getElementById('dw-ty');if(t)t.remove();}
  async function callMake(msg){
    history.push({role:'user',content:msg});
    try{
      const r=await fetch(WEBHOOK_URL,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({message:msg,sessionId:sid,history:history.slice(-6)})});
      const data=await r.json();
      const reply=data.reply||data.response||data.message||data.text||'';
      if(reply){history.push({role:'assistant',content:reply});return reply;}
      throw new Error('no reply');
    }catch(e){
      return '¡Ups! Tuve un problema. Te puedo conectar directamente con nuestro equipo por WhatsApp 👉 <wa>';
    }
  }
  async function send(){
    const inp=document.getElementById('dw-inp');
    const text=inp.value.trim();if(!text)return;
    inp.value='';
    document.getElementById('dw-qr').style.display='none';
    addM(text,true);showTyping();
    const reply=await callMake(text);
    rmTyping();
    if(reply.includes('<wa>')){
      const c=document.getElementById('dw-msgs');
      const d=document.createElement('div');d.className='dm b';
      const b=document.createElement('div');b.className='db';
      b.innerHTML='¡Ups! Tuve un problema. Te conecto con nuestro equipo 👉 <a href="'+WA+'" target="_blank" style="color:#25D366;font-weight:700">Escribir por WhatsApp</a>';
      const ti=document.createElement('div');ti.className='dt';ti.textContent=t();
      d.appendChild(b);d.appendChild(ti);c.appendChild(d);c.scrollTop=c.scrollHeight;
    } else {
      addM(reply,false);
    }
  }
  window.dwQ=function(text){document.getElementById('dw-qr').style.display='none';addM(text,true);showTyping();callMake(text).then(r=>{rmTyping();if(r.includes('<wa>')){const c=document.getElementById('dw-msgs');const d=document.createElement('div');d.className='dm b';const b=document.createElement('div');b.className='db';b.innerHTML='Tuve un problema. Escríbenos 👉 <a href="'+WA+'" target="_blank" style="color:#25D366;font-weight:700">WhatsApp</a>';const ti=document.createElement('div');ti.className='dt';ti.textContent=t();d.appendChild(b);d.appendChild(ti);c.appendChild(d);c.scrollTop=c.scrollHeight;}else{addM(r,false);}});};
})();
</script>

